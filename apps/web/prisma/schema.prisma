generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  passwordHash        String?
  googleId            String?         @unique
  appleId             String?         @unique
  username            String?         @unique
  displayName         String
  avatarId            String?
  isPublic            Boolean         @default(true)
  hideCollectionValue Boolean         @default(false)
  country             String?
  twitterHandle       String?
  instagramHandle     String?
  tiktokHandle        String?
  avatarUrl           String?
  stripeCustomerId    String?
  stripeAccountId     String?
  isVerifiedSeller    Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  bids                Bid[]
  listings            Listing[]
  orders              Order[]         @relation("buyer")
  sales               Order[]         @relation("seller")
  portfolios          Portfolio[]
  watchlistItems      WatchlistItem[]
}

model PokemonSet {
  id           String  @id @default(cuid())
  name         String
  code         String  @unique
  totalCards   Int
  releaseYear  Int
  imageUrl     String?
  language     String  @default("EN")
  printedTotal Int?
  cards        Card[]
}

model Card {
  id                     String                  @id @default(cuid())
  gameType               GameType                @default(POKEMON)
  name                   String
  setName                String
  setCode                String
  cardNumber             String
  rarity                 String?
  imageUrl               String?
  pokemonTcgId           String?                 @unique
  language               String                  @default("EN")
  createdAt              DateTime                @default(now())
  setId                  String?
  supertype              String?
  set                    PokemonSet?             @relation(fields: [setId], references: [id])
  prices                 CardPrice[]
  gradedPriceComparisons GradedPriceComparison[]
  listings               Listing[]
  portfolioItems         PortfolioItem[]
  priceHistory           PriceHistory[]
  psaCertCaches          PsaCertCache[]
  watchlistItems         WatchlistItem[]
}

model CardPrice {
  id                 String    @id @default(cuid())
  cardId             String
  date               DateTime  @default(now())
  priceLow           Float?
  priceMid           Float?
  priceHigh          Float?
  priceMarket        Float?
  ebaySoldAvg        Float?
  priceChartingValue Float?
  gradedPSA10        Float?
  gradedPSA9         Float?
  gradedBGS10        Float?
  gradedBGS95        Float?
  expectedValue      Float?
  ebayBuyNowLow      Float?
  lastUpdated        DateTime?
  isStale            Boolean   @default(false)
  listingCount       Int       @default(0)
  variant            String?
  card               Card      @relation(fields: [cardId], references: [id])

  @@index([cardId, date])
}

model PriceHistory {
  id     String   @id @default(cuid())
  cardId String
  price  Float
  date   DateTime @default(now())
  source String   @default("ebay")
  card   Card     @relation(fields: [cardId], references: [id])

  @@index([cardId, date])
}

model Portfolio {
  id        String          @id @default(cuid())
  userId    String
  name      String
  isPublic  Boolean         @default(false)
  shareSlug String?         @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id])
  items     PortfolioItem[]
}

model PortfolioItem {
  id                String    @id @default(cuid())
  portfolioId       String
  cardId            String
  quantity          Int       @default(1)
  condition         Condition @default(NEAR_MINT)
  isGraded          Boolean   @default(false)
  gradeCompany      String?
  gradeValue        Float?
  purchasePrice     Float?
  purchaseDate      DateTime?
  notes             String?
  addedAt           DateTime  @default(now())
  valuationOverride Float?
  certNumber        String?   @unique
  subGradeCentering Float?
  subGradeCorners   Float?
  subGradeEdges     Float?
  subGradeSurface   Float?
  card              Card      @relation(fields: [cardId], references: [id])
  portfolio         Portfolio @relation(fields: [portfolioId], references: [id])
}

model PsaCertCache {
  id            String    @id @default(cuid())
  certNumber    String    @unique
  cardId        String?
  grade         String
  grader        String    @default("PSA")
  popCount      Int?
  lastSalePrice Float?
  lastSaleDate  DateTime?
  saleCount30d  Int       @default(0)
  fetchedAt     DateTime  @default(now())
  expiresAt     DateTime  @updatedAt
  card          Card?     @relation(fields: [cardId], references: [id])

  @@index([cardId])
}

model GradedPriceComparison {
  id            String   @id @default(cuid())
  cardId        String
  grade         String
  grader        String
  price         Float
  lastFetchedAt DateTime @default(now())
  card          Card     @relation(fields: [cardId], references: [id])

  @@unique([cardId, grade, grader])
}

model Listing {
  id              String        @id @default(cuid())
  sellerId        String
  cardId          String
  title           String
  description     String?
  condition       Condition
  isGraded        Boolean       @default(false)
  gradeCompany    String?
  gradeValue      Float?
  buyNowPrice     Float
  imageUrls       String[]
  status          ListingStatus @default(ACTIVE)
  commissionPct   Float         @default(8)
  stripeProductId String?
  createdAt       DateTime      @default(now())
  expiresAt       DateTime?
  card            Card          @relation(fields: [cardId], references: [id])
  seller          User          @relation(fields: [sellerId], references: [id])
  orders          Order[]
}

model Order {
  id                    String      @id @default(cuid())
  listingId             String
  buyerId               String
  sellerId              String
  amount                Float
  platformFee           Float
  sellerPayout          Float
  stripePaymentIntentId String?
  stripeTransferId      String?
  status                OrderStatus @default(PENDING)
  shippingAddress       Json?
  createdAt             DateTime    @default(now())
  completedAt           DateTime?
  buyer                 User        @relation("buyer", fields: [buyerId], references: [id])
  listing               Listing     @relation(fields: [listingId], references: [id])
  seller                User        @relation("seller", fields: [sellerId], references: [id])
}

model Bid {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  amount    Float
  isWinning Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  cardId  String
  addedAt DateTime @default(now())
  card    Card     @relation(fields: [cardId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@unique([userId, cardId])
}

model SyncLog {
  id            String   @id @default(cuid())
  runAt         DateTime @default(now())
  newSets       Int      @default(0)
  updatedSets   Int      @default(0)
  newCards      Int      @default(0)
  updatedCards  Int      @default(0)
  updatedPrices Int      @default(0)
  errors        String?
  duration      Int
}

enum GameType {
  POKEMON
  MTG
  YUGIOH
  SPORTS
  ONE_PIECE
  LORCANA
  OTHER
}

enum Condition {
  MINT
  NEAR_MINT
  LIGHTLY_PLAYED
  MODERATELY_PLAYED
  HEAVILY_PLAYED
  DAMAGED
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  DISPUTED
  REFUNDED
  CANCELLED
}
