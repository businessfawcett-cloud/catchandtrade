{
  "name": "catchandtrade",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "record-snapshot": "node packages/db/scripts/record-price-snapshot.js",
    "stripe:listen": "stripe listen --forward-to localhost:3003/api/webhooks/stripe"
  },
  "dependencies": {
    "install": "^0.13.0",
    "metro": "^0.82.2",
    "metro-config": "^0.82.2",
    "metro-core": "^0.82.2",
    "metro-resolver": "^0.82.2",
    "metro-runtime": "^0.82.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native-gesture-handler": "^2.30.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "packageManager": "npm@10.0.0"
}
